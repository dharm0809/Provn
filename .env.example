# ============================================================
# .env — compose-level interpolation only.
#
# Docker Compose reads THIS file for ${VAR} expansion in
# docker-compose.yml itself (image tags, host port bindings). Variables
# the *containers* read live in dedicated per-service env files so we
# avoid the "forgot to forward var X" class of bug:
#
#   .env.gateway     → gateway container env (everything the gateway reads)
#   .env.openwebui   → OpenWebUI container env
#
# Copy each .example to its non-example name and fill in real values.
# ============================================================

# Docker image tag for the gateway service. Leave empty to build locally
# via `docker compose build`; set to an ECR/registry tag for prod pulls.
GATEWAY_IMAGE=

# Host port mappings (override to avoid local-dev collisions).
GATEWAY_PORT=8002
OPENWEBUI_PORT=3000
