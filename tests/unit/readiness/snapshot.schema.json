{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ReadinessReport",
  "description": "Shape of GET /v1/readiness response. Changes require explicit snapshot refresh.",
  "type": "object",
  "required": ["status", "generated_at", "cache_age_s", "gateway_id", "summary", "checks"],
  "additionalProperties": true,
  "properties": {
    "status": { "type": "string", "enum": ["ready", "degraded", "unready"] },
    "generated_at": { "type": "string" },
    "cache_age_s": { "type": "number" },
    "gateway_id": { "type": "string" },
    "summary": {
      "type": "object",
      "required": ["green", "amber", "red", "total"],
      "properties": {
        "green": { "type": "integer" },
        "amber": { "type": "integer" },
        "red": { "type": "integer" },
        "total": { "type": "integer" }
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "category", "severity", "status", "detail", "evidence", "elapsed_ms"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "category": { "type": "string" },
          "severity": { "type": "string", "enum": ["sec", "int", "ops", "warn"] },
          "status": { "type": "string", "enum": ["green", "amber", "red"] },
          "detail": { "type": "string" },
          "remediation": { "type": ["string", "null"] },
          "evidence": { "type": "object" },
          "elapsed_ms": { "type": "integer" }
        }
      }
    }
  }
}
