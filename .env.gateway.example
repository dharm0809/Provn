# WALACOR_DLP_ENABLED=true   # Enable DLP data classification for financial, health, secrets, and infrastruc...
# WALACOR_DRIFT_ACCURACY_DROP_THRESHOLD=0.05   # Minimum baseline→recent accuracy drop that triggers a drift signal
# WALACOR_DRIFT_CHECK_INTERVAL_S=600   # Seconds between drift monitor accuracy checks
# WALACOR_DRIFT_MIN_COVERAGE=0.3   # Minimum signal-coverage ratio in both windows before drift is evaluated
# WALACOR_DRIFT_MIN_SAMPLES=50   # Minimum signal-bearing samples required in both baseline and recent windows b...
# WALACOR_DRIFT_WINDOW_HOURS=1   # Recent-accuracy window size for drift detection (hours)
# WALACOR_EXPORT_BATCH_SIZE=50   # Batch size before exporting
# WALACOR_EXPORT_ENABLED=false   # Export audit records to external destination
# WALACOR_EXPORT_FILE_MAX_SIZE_MB=100   # Max file size before rotation (MB)
# WALACOR_EXPORT_FILE_PATH=/var/walacor/export/audit.jsonl   # JSONL output path
# WALACOR_EXPORT_FLUSH_INTERVAL=30   # Max seconds between flushes
# WALACOR_EXPORT_S3_BUCKET=   # S3 bucket name for S3 exporter
# WALACOR_EXPORT_S3_PREFIX=walacor-audit/   # S3 key prefix
# WALACOR_EXPORT_S3_REGION=us-east-1   # AWS region for S3 exporter
# WALACOR_EXPORT_TYPE=file   # Export type: file, webhook (s3 requires boto3)
# WALACOR_EXPORT_WEBHOOK_HEADERS=   # JSON dict of extra HTTP headers
# WALACOR_EXPORT_WEBHOOK_URL=   # Webhook URL (Splunk HEC, Datadog, etc.)
# WALACOR_GATEWAY_WEB_SEARCH_ENABLED=true   # Deprecated — use web_search_enabled
# WALACOR_GENERIC_AUTO_DETECT=true   # When true, GenericAdapter auto-detects OpenAI-compat, HuggingFace, and Ollama...
# WALACOR_HTTP_KEEPALIVE_EXPIRY=30   # Keepalive expiry in seconds
# WALACOR_HTTP_POOL_MAX_CONNECTIONS=100   # Max HTTP connections in pool
# WALACOR_HTTP_POOL_MAX_KEEPALIVE=20   # Max keepalive connections per host
# WALACOR_IMAGE_OCR_ENABLED=false   # Enable Tesseract OCR + PII detection on images
# WALACOR_IMAGE_OCR_MAX_SIZE_MB=10   # Skip OCR for images larger than this (MB)
# WALACOR_IP_RATE_LIMIT_RPM=300   # Per-IP pre-auth rate limit (requests per minute)
# WALACOR_IP_RATE_LIMIT_TRUSTED_PROXIES=   # Comma-separated list of trusted proxy IPs/CIDRs. When request.client.host is ...
# WALACOR_JWT_TENANT_CLAIM=tenant_id   # JWT claim that carries the caller's tenant. Common alternatives: 'tenant', 'o...
# WALACOR_LINEAGE_AUTH_REQUIRED=true   # Require API key on /v1/lineage/* endpoints
# WALACOR_LINEAGE_LOCAL_READER=true   # When no Walacor client is configured, fall back to the SQLite-backed `Lineage...
# WALACOR_MODEL_SIGNING_ENABLED=false   # Verify OpenSSF model signatures during discovery.
# WALACOR_ONNX_INFERENCE_TIMEOUT_MS=100   # Hot-path ONNX inference timeout in milliseconds; on overrun callers fall back...
# WALACOR_OPA_POLICY_PATH=/v1/data/walacor/gateway/allow   # OPA decision document path.
# WALACOR_OPA_URL=http://localhost:8181   # OPA REST API URL.
# WALACOR_OPENAI_WEB_SEARCH_ENABLED=false   # Deprecated — use web_search_enabled
# WALACOR_PII_SANITIZATION_ENABLED=false   # Strip high-risk PII from prompt before sending to LLM, restore in response. R...
# WALACOR_PII_SANITIZATION_MODE=replace   # Sanitization mode: 'replace' (placeholder tokens) or 'redact' (remove entirel...
# WALACOR_PII_SANITIZATION_TYPES=SSN,CREDIT_CARD,AWS_ACCESS_KEY,API_KEY   # Comma-separated PII types to sanitize before forwarding to LLM.
# WALACOR_PLUGIN_AUTH_REQUIRED=false   # When True, /v1/openwebui/* and /api/* paths go through the normal auth middle...
# WALACOR_POLICY_ENGINE=builtin   # Policy engine: 'builtin' or 'opa'.
# WALACOR_POST_PROMOTION_COOLDOWN_H=12   # Hours after an auto-rollback during which the same model is exempt from furth...
# WALACOR_POST_PROMOTION_INTERVAL_S=600   # Seconds between post-promotion validation cycles
# WALACOR_POST_PROMOTION_MIN_SAMPLES=200   # Minimum signal-bearing samples in pre AND post windows before auto-rollback f...
# WALACOR_POST_PROMOTION_SETTLE_MINUTES=15   # Minutes after a promotion before its candidate is eligible for evaluation
# WALACOR_POST_PROMOTION_THRESHOLD=0.05   # Pre→post-promotion accuracy drop that triggers an auto-rollback
# WALACOR_POST_PROMOTION_WINDOW_H=24   # Hours since promotion within which a candidate is eligible for auto-rollback ...
# WALACOR_PRESIDIO_PII_ENABLED=false   # Enable Presidio NER PII analyzer (requires pip install 'walacor-gateway[presi...
# WALACOR_PROMPT_GUARD_ENABLED=false   # Enable Prompt Guard 2 prompt injection detector (requires pip install 'walaco...
# WALACOR_PROMPT_GUARD_MODEL=meta-llama/Prompt-Guard-2-22M   # HuggingFace model ID for Prompt Guard 2 (22M or 86M variant).
# WALACOR_PROMPT_GUARD_THRESHOLD=0.9   # Classification threshold for injection detection (0.0-1.0).
# WALACOR_PROVIDER_ANTHROPIC_BETA_HEADERS=   # Comma-separated list of anthropic-beta header values to send on every Anthrop...
# WALACOR_RECORD_SIGNING_ENABLED=false   # Sign record hashes with Ed25519 for non-repudiation
# WALACOR_RECORD_SIGNING_KEY_PATH=   # Path to Ed25519 private key PEM file
# WALACOR_REJECT_CHUNKED_TRANSFER=true   # When True (default), requests with `Transfer-Encoding: chunked` are rejected ...
# WALACOR_SEMANTIC_CACHE_EMBEDDING_MODEL=   # Ollama model for embeddings (empty = exact-match only)
# WALACOR_SEMANTIC_CACHE_ENABLED=true   # Cache LLM responses for identical prompts (exact-match SHA-256 key)
# WALACOR_SEMANTIC_CACHE_MAX_ENTRIES=10000   # Max cached entries (oldest-first eviction)
# WALACOR_SEMANTIC_CACHE_SIMILARITY_THRESHOLD=0.95   # Cosine similarity threshold (Phase 2 embedding cache, unused in exact-match m...
# WALACOR_SEMANTIC_CACHE_TTL=3600   # Cache TTL in seconds
# WALACOR_SESSION_HEADER_NAMES=X-Session-ID,X-OpenWebUI-Chat-Id,X-Chat-Id   # Comma-separated list of request header names to check for session ID, in prio...
# WALACOR_SHADOW_POLICY_ENABLED=false   # Enable shadow policy mode (log decisions without enforcing).
# WALACOR_SHARED_CAPABILITY_CACHE_PATH=   # (TODO, not implemented) SQLite path for cross-worker model capability cache. ...
# WALACOR_SKIP_SYSTEM_TASK_AUDIT=false   # Skip audit records for system-generated requests (tag/title/suggestion genera...
# WALACOR_STREAM_PII_MODE=warn   # Behaviour when PII is detected mid-stream: warn|abort|redact
# WALACOR_TOKEN_RATE_LIMIT_ENABLED=false   # Enable token-based rate limiting (sliding window per scope)
# WALACOR_TOKEN_RATE_LIMIT_MAX_TOKENS=100000   # Max tokens per window per scope
# WALACOR_TOKEN_RATE_LIMIT_SCOPE=user   # Rate limit scope: user, key, tenant, global
# WALACOR_TOKEN_RATE_LIMIT_WINDOW=60   # Rate limit window in seconds
# WALACOR_TOOL_STRATEGY=auto   # Deprecated — strategy is automatic per-request
# WALACOR_WAL_BATCH_ENABLED=true   # Enable group commit batching for WAL writes
# WALACOR_WAL_BATCH_FLUSH_MS=10   # Max flush delay in milliseconds
# WALACOR_WAL_BATCH_MAX_SIZE=50   # Max records per batch before immediate flush
