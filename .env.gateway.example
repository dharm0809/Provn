# Copy to .env.gateway and fill in your values.
# .env.gateway is gitignored — never commit real credentials.

# ── Walacor backend storage ──────────────────────────────────────────────────
WALACOR_SERVER=https://sandbox.walacor.com/api
WALACOR_USERNAME=your-username
WALACOR_PASSWORD=your-password

# ── Governance mode ──────────────────────────────────────────────────────────
# Set to true to disable governance and run as transparent proxy.
# WALACOR_SKIP_GOVERNANCE=false
# WALACOR_ENFORCEMENT_MODE=enforced    # enforced | audit_only

# ── Tenant identity ──────────────────────────────────────────────────────────
WALACOR_GATEWAY_TENANT_ID=your-tenant-id

# ── LLM provider credentials (set whichever you use) ────────────────────────
# WALACOR_GATEWAY_PROVIDER=openai      # openai | ollama | anthropic | huggingface | generic
# WALACOR_PROVIDER_OPENAI_KEY=sk-...
# WALACOR_PROVIDER_ANTHROPIC_KEY=sk-ant-...
# WALACOR_PROVIDER_OLLAMA_URL=http://localhost:11434

# ── Caller authentication ────────────────────────────────────────────────────
# WALACOR_GATEWAY_API_KEYS=key1,key2
# WALACOR_AUTH_MODE=api_key            # api_key | jwt | both

# ── JWT/SSO authentication ───────────────────────────────────────────────────
# Install: pip install 'walacor-gateway[auth]'
# WALACOR_JWT_SECRET=                  # shared secret for HS256
# WALACOR_JWT_JWKS_URL=               # JWKS endpoint for RS256/ES256
# WALACOR_JWT_ISSUER=                 # expected iss claim
# WALACOR_JWT_AUDIENCE=               # expected aud claim
# WALACOR_JWT_ALGORITHMS=RS256

# ── Embedded control plane ───────────────────────────────────────────────────
# WALACOR_CONTROL_PLANE_ENABLED=true
# WALACOR_CONTROL_PLANE_DB_PATH=      # default: alongside WAL db

# ── Remote control plane (fleet mode — optional) ─────────────────────────────
# Only needed when connecting to a remote/primary gateway for fleet sync.
# WALACOR_CONTROL_PLANE_URL=https://primary-gateway:8000
# WALACOR_CONTROL_PLANE_API_KEY=your-cp-api-key

# ── Lineage dashboard ────────────────────────────────────────────────────────
# WALACOR_LINEAGE_ENABLED=true

# ── Multi-model routing ──────────────────────────────────────────────────────
# WALACOR_MODEL_ROUTING_JSON=[{"pattern":"qwen3*","provider":"ollama","url":"http://localhost:11434"}]

# ── Resilience layer (model groups, circuit breakers, retry) ─────────────────
# WALACOR_MODEL_GROUPS_JSON=          # JSON: {"gpt-*": [{"url":"...","key":"...","weight":7}]}

# ── Redis (multi-replica state sharing) ──────────────────────────────────────
# WALACOR_REDIS_URL=redis://redis-svc:6379/0

# ── Tool-aware gateway + web search ──────────────────────────────────────────
# Install for DuckDuckGo: pip install 'walacor-gateway[search]'
# WALACOR_TOOL_AWARE_ENABLED=false
# WALACOR_WEB_SEARCH_ENABLED=false
# WALACOR_WEB_SEARCH_PROVIDER=duckduckgo  # duckduckgo | brave | serpapi
# WALACOR_WEB_SEARCH_API_KEY=             # required for brave/serpapi
# WALACOR_MCP_SERVERS_JSON=

# ── Thinking strip (reasoning models) ────────────────────────────────────────
# WALACOR_THINKING_STRIP_ENABLED=true

# ── Llama Guard (model-based content safety) ─────────────────────────────────
# Requires: ollama pull llama-guard3
# WALACOR_LLAMA_GUARD_ENABLED=false

# ── Prompt caching ───────────────────────────────────────────────────────────
# WALACOR_PROMPT_CACHING_ENABLED=true  # auto-inject cache_control for Anthropic

# ── Token budget ─────────────────────────────────────────────────────────────
# WALACOR_TOKEN_BUDGET_ENABLED=false
# WALACOR_TOKEN_BUDGET_MAX_TOKENS=1000000
# WALACOR_TOKEN_BUDGET_PERIOD=monthly  # daily | monthly

# ── Rate limiting ────────────────────────────────────────────────────────────
# WALACOR_RATE_LIMIT_ENABLED=false
# WALACOR_RATE_LIMIT_RPM=60
# WALACOR_RATE_LIMIT_PER_MODEL=true

# ── Alerting (webhooks, Slack, PagerDuty) ────────────────────────────────────
# WALACOR_WEBHOOK_URLS=               # comma-separated webhook URLs
# WALACOR_PAGERDUTY_ROUTING_KEY=      # PagerDuty Events API v2 routing key
# WALACOR_ALERT_BUDGET_THRESHOLDS=70,90,100

# ── Session integrity chain ──────────────────────────────────────────────────
# WALACOR_SESSION_CHAIN_ENABLED=true

# ── OpenTelemetry ────────────────────────────────────────────────────────────
# Install: pip install 'walacor-gateway[telemetry]'
# WALACOR_OTEL_ENABLED=false
# WALACOR_OTEL_ENDPOINT=http://localhost:4317

# ── Observability ────────────────────────────────────────────────────────────
# WALACOR_LOG_LEVEL=INFO
# WALACOR_METRICS_ENABLED=true

# ── Server ───────────────────────────────────────────────────────────────────
# WALACOR_GATEWAY_HOST=0.0.0.0
# WALACOR_GATEWAY_PORT=8000
# WALACOR_UVICORN_WORKERS=1           # >1 only with Redis
