# ============================================================
# Walacor Gateway — gateway container env (loaded by docker-compose
# via `env_file: .env.gateway`). Copy this file to `.env.gateway`
# and fill in real values. `.env.gateway` is gitignored.
#
# Every WALACOR_* setting the gateway reads has an entry here; new
# fields added to `src/gateway/config.py` should also be added here
# so the test_env_propagation.py CI check passes.
#
# Companion files:
#   .env                  compose-level interpolation only
#                         (GATEWAY_IMAGE, GATEWAY_PORT, OPENWEBUI_PORT)
#   .env.openwebui        OpenWebUI container env (gateway client key,
#                         WEBUI_SECRET_KEY, WEBUI_NAME)
# ============================================================

# ── Identity ──────────────────────────────────────────────
WALACOR_GATEWAY_TENANT_ID=dev-tenant
WALACOR_GATEWAY_ID=                    # auto-generated UUID if empty

# ── Walacor backend storage ───────────────────────────────
# When all three are set, records go directly to Walacor + local WAL (dual-write).
WALACOR_SERVER=http://32.196.5.38/api
WALACOR_USERNAME=
WALACOR_PASSWORD=
# Run: python scripts/setup_walacor_schemas.py to create these schemas
WALACOR_EXECUTIONS_ETID=9000031   # chain-aware schema; created by scripts/setup_walacor_schemas.py
WALACOR_ATTEMPTS_ETID=9000032
WALACOR_TOOL_EVENTS_ETID=9000033  # includes sources + prompt_id + mcp_server_name
WALACOR_LIFECYCLE_EVENTS_ETID=9000034   # ONNX lifecycle events (training, candidate, shadow, promotion, rejection)

# ── Governance / control plane ────────────────────────────
WALACOR_CONTROL_PLANE_URL=
WALACOR_CONTROL_PLANE_API_KEY=
WALACOR_SKIP_GOVERNANCE=false          # true = transparent proxy, audit only
WALACOR_ENFORCEMENT_MODE=enforced      # enforced | audit_only

# ── Embedded control plane ────────────────────────────────
WALACOR_CONTROL_PLANE_ENABLED=true     # enable local SQLite control plane
WALACOR_CONTROL_PLANE_DB_PATH=         # default: alongside WAL db

# ── Auth ──────────────────────────────────────────────────
WALACOR_GATEWAY_API_KEYS=              # comma-separated keys for callers
WALACOR_AUTH_MODE=api_key              # api_key | jwt | both

# ── JWT/SSO (enterprise SSO via Okta/Azure AD/Auth0) ─────
# Install: pip install 'walacor-gateway[auth]'
WALACOR_JWT_SECRET=                    # shared secret for HS256
WALACOR_JWT_JWKS_URL=                  # JWKS endpoint for RS256/ES256 (OIDC providers)
WALACOR_JWT_ISSUER=                    # expected iss claim
WALACOR_JWT_AUDIENCE=                  # expected aud claim
WALACOR_JWT_ALGORITHMS=RS256           # comma-separated (RS256,ES256,HS256)
WALACOR_JWT_USER_CLAIM=sub             # JWT claim for user ID
WALACOR_JWT_EMAIL_CLAIM=email          # JWT claim for email
WALACOR_JWT_ROLES_CLAIM=roles          # JWT claim for roles
WALACOR_JWT_TEAM_CLAIM=                # JWT claim for team (empty = disabled)

# ── Provider URLs and keys ────────────────────────────────
WALACOR_GATEWAY_PROVIDER=openai        # default provider for path-based routing
WALACOR_PROVIDER_OPENAI_URL=https://api.openai.com
# Either name accepted — OPENAI_API_KEY mirrors industry convention and is
# resolved via validation_alias on `provider_openai_key` in config.py.
OPENAI_API_KEY=
# WALACOR_PROVIDER_OPENAI_KEY=         # (alternative spelling, same field)
WALACOR_PROVIDER_ANTHROPIC_URL=https://api.anthropic.com
ANTHROPIC_API_KEY=
# WALACOR_PROVIDER_ANTHROPIC_KEY=      # (alternative spelling, same field)
# WALACOR_PROVIDER_OLLAMA_URL: set by docker-compose for the gateway-ollama
# service hostname. Override here only for native (non-Docker) deployments.
WALACOR_PROVIDER_OLLAMA_KEY=           # usually empty for local Ollama
WALACOR_PROVIDER_HUGGINGFACE_URL=
WALACOR_PROVIDER_HUGGINGFACE_KEY=
WALACOR_GENERIC_UPSTREAM_URL=
WALACOR_GENERIC_MODEL_PATH=$.model
WALACOR_GENERIC_PROMPT_PATH=$.messages[*].content
WALACOR_GENERIC_RESPONSE_PATH=$.choices[0].message.content
WALACOR_OLLAMA_DIGEST_CACHE_TTL=1800

# ── Multi-model routing ──────────────────────────────────
# JSON array or path to JSON file. Checked before path-based routing.
# Example: [{"pattern":"gpt-*","provider":"openai"},{"pattern":"claude-*","provider":"anthropic"}]
WALACOR_MODEL_ROUTING_JSON=

# ── Resilience layer (model groups, circuit breakers) ────
# JSON: {"gpt-*": [{"url": "https://api1.openai.com", "key": "sk-1", "weight": 7}]}
WALACOR_MODEL_GROUPS_JSON=
WALACOR_CIRCUIT_BREAKER_FAIL_MAX=5     # failures before circuit opens
WALACOR_CIRCUIT_BREAKER_RESET_TIMEOUT=30.0  # seconds before half-open retry
WALACOR_RETRY_MAX_ATTEMPTS=3           # max forward retry attempts

# ── Redis (multi-replica state sharing) ──────────────────
WALACOR_REDIS_URL=                     # redis://redis-svc:6379/0 for multi-replica

# ── Tool-aware gateway + web search ──────────────────────
WALACOR_TOOL_AWARE_ENABLED=true
WALACOR_TOOL_MAX_ITERATIONS=10
WALACOR_TOOL_EXECUTION_TIMEOUT_MS=30000
WALACOR_TOOL_CONTENT_ANALYSIS_ENABLED=true
WALACOR_WEB_SEARCH_ENABLED=true        # single flag: gateway executes web search for all providers
WALACOR_WEB_SEARCH_PROVIDER=duckduckgo # duckduckgo | brave | serpapi
WALACOR_WEB_SEARCH_API_KEY=            # required for brave / serpapi
WALACOR_WEB_SEARCH_MAX_RESULTS=5

# ── OpenWebUI integration (auto-configures on startup) ───
WALACOR_OPENWEBUI_URL=                 # e.g. http://openwebui:8080 from the gateway container
WALACOR_OPENWEBUI_API_KEY=             # OpenWebUI admin API key for outbound filter install
WALACOR_MCP_SERVERS_JSON=              # JSON array or file path for MCP server configs
WALACOR_MCP_ALLOWED_COMMANDS=          # Extra allowed stdio commands (comma-separated, e.g. "deno,bun")
WALACOR_TOOL_MAX_OUTPUT_BYTES=1048576  # Max tool output size (1MB default, prevents context exhaustion)
WALACOR_TOOL_LOOP_TOTAL_TIMEOUT_MS=120000  # Max wall-clock time for all tool iterations (120s)

# ── Thinking strip (reasoning models) ────────────────────
# Strip <think>...</think> blocks from Ollama/Qwen3/DeepSeek-R1 responses.
# Stripped content stored separately as thinking_content in audit record.
WALACOR_THINKING_STRIP_ENABLED=true

# ── Llama Guard (model-based content safety) ─────────────
# Requires: ollama pull llama-guard3
WALACOR_LLAMA_GUARD_ENABLED=false
WALACOR_LLAMA_GUARD_MODEL=llama-guard3
WALACOR_LLAMA_GUARD_OLLAMA_URL=        # defaults to WALACOR_PROVIDER_OLLAMA_URL
WALACOR_LLAMA_GUARD_TIMEOUT_MS=5000

# ── Prompt caching ───────────────────────────────────────
WALACOR_PROMPT_CACHING_ENABLED=true    # auto-inject cache_control for Anthropic

# ── Content analysis ─────────────────────────────────────
WALACOR_RESPONSE_POLICY_ENABLED=true
WALACOR_PII_DETECTION_ENABLED=true
WALACOR_TOXICITY_DETECTION_ENABLED=false
WALACOR_TOXICITY_DENY_TERMS=           # comma-separated extra terms

# ── Token budget ─────────────────────────────────────────
WALACOR_TOKEN_BUDGET_ENABLED=false
WALACOR_TOKEN_BUDGET_PERIOD=monthly    # daily | monthly
WALACOR_TOKEN_BUDGET_MAX_TOKENS=0      # 0 = unlimited

# ── Rate limiting ────────────────────────────────────────
WALACOR_RATE_LIMIT_ENABLED=false
WALACOR_RATE_LIMIT_RPM=60             # requests per minute
WALACOR_RATE_LIMIT_PER_MODEL=true     # per user+model vs per user only

# ── Alerting (webhooks, Slack, PagerDuty) ────────────────
WALACOR_WEBHOOK_URLS=                  # comma-separated webhook URLs
WALACOR_PAGERDUTY_ROUTING_KEY=        # PagerDuty Events API v2 routing key
WALACOR_ALERT_BUDGET_THRESHOLDS=70,90,100

# ── Session chain ────────────────────────────────────────
WALACOR_SESSION_CHAIN_ENABLED=true
WALACOR_SESSION_CHAIN_MAX_SESSIONS=10000
WALACOR_SESSION_CHAIN_TTL=3600

# ── Completeness tracking ────────────────────────────────
WALACOR_COMPLETENESS_ENABLED=true
WALACOR_ATTEMPTS_RETENTION_HOURS=168   # 7 days

# ── Cache and sync intervals ─────────────────────────────
WALACOR_ATTESTATION_CACHE_TTL=300
WALACOR_POLICY_STALENESS_THRESHOLD=900
WALACOR_SYNC_INTERVAL=60

# ── WAL (local SQLite fallback storage) ──────────────────
# WALACOR_WAL_PATH: set by docker-compose to /var/walacor/wal (the volume
# mount). Override here only for native (non-Docker) deployments.
WALACOR_WAL_MAX_SIZE_GB=10.0
WALACOR_WAL_MAX_AGE_HOURS=72.0
WALACOR_WAL_HIGH_WATER_MARK=10000
WALACOR_MAX_STREAM_BUFFER_BYTES=10485760
# WAL delivery resilience (only meaningful when WALACOR_CONTROL_PLANE_URL is set
# and DeliveryWorker runs — for direct-Walacor deployments these have no effect).
WALACOR_WAL_DELIVERY_MAX_RETRIES=10        # per-record retries before DLQ promotion
WALACOR_WAL_DELIVERY_BATCH_ERROR_BUDGET=5  # failures per batch before exponential backoff

# ── OpenTelemetry ────────────────────────────────────────
# Install: pip install 'walacor-gateway[telemetry]'
WALACOR_OTEL_ENABLED=false
WALACOR_OTEL_ENDPOINT=http://localhost:4317   # OTLP gRPC endpoint
WALACOR_OTEL_SERVICE_NAME=walacor-gateway

# ── Lineage dashboard ────────────────────────────────────
WALACOR_LINEAGE_ENABLED=true              # dashboard at /lineage/
WALACOR_READINESS_ENABLED=true            # GET /v1/readiness (31-check rollup; k8s-friendly)
WALACOR_CONNECTIONS_ENABLED=true          # GET /v1/connections (10-tile subsystem health cockpit)
WALACOR_PLUGIN_EVENT_GOVERNANCE_ENABLED=true  # POST /v1/openwebui/events governance pipeline
WALACOR_STRICT_MODEL_ALLOWLIST=false      # true = require explicit attestation; no auto-attest on first use

# ── Network tuning ─────────────────────────────────────
WALACOR_PROVIDER_TIMEOUT=120.0         # provider HTTP request timeout (120s for CPU inference + thinking models)
WALACOR_PROVIDER_CONNECT_TIMEOUT=10.0   # provider connection timeout (seconds)
WALACOR_PROVIDER_MAX_CONNECTIONS=200    # max concurrent provider connections
WALACOR_PROVIDER_MAX_KEEPALIVE=50       # max keepalive provider connections
WALACOR_SSE_KEEPALIVE_INTERVAL=15.0     # SSE keepalive ping interval (seconds)
WALACOR_DELIVERY_BATCH_SIZE=50          # WAL delivery batch size per cycle
WALACOR_DISK_DEGRADED_THRESHOLD=0.8     # WAL disk usage threshold (0-1) for degraded
WALACOR_COMPLETENESS_TIMEOUT=2.0        # completeness middleware write timeout (seconds)
WALACOR_MAX_REQUEST_BODY_MB=50.0       # max request body size (rejects with 413 if exceeded)
WALACOR_CORS_ALLOWED_ORIGINS=          # comma-separated CORS origins (empty = same-origin only, * = allow all)
WALACOR_OPA_FAIL_CLOSED=false          # block requests when OPA policy server is unavailable

# ── Adaptive Gateway ────────────────────────────────────
WALACOR_STARTUP_PROBES_ENABLED=true
WALACOR_PROVIDER_HEALTH_CHECK_ON_STARTUP=true
WALACOR_CAPABILITY_PROBE_TTL_SECONDS=86400
WALACOR_IDENTITY_VALIDATION_ENABLED=true
WALACOR_DISK_MONITOR_ENABLED=true
WALACOR_DISK_MIN_FREE_PERCENT=5.0
WALACOR_RESOURCE_MONITOR_INTERVAL_SECONDS=60

# ── Intelligence / ONNX Self-Learning ──────────
WALACOR_INTELLIGENCE_ENABLED=true                 # capture ONNX verdicts + enable distillation/shadow-eval pipeline
WALACOR_INTELLIGENCE_DB_PATH=                     # SQLite path for verdict store (empty = {wal_path}/intelligence.db)
WALACOR_ONNX_MODELS_BASE_PATH=                    # base dir for ONNX model artifacts (empty = src/gateway/models/)
WALACOR_VERDICT_RETENTION_DAYS=30                 # retention window for captured verdicts
WALACOR_DISTILLATION_SCHEDULE_CRON=0 2 * * *      # cron for nightly distillation job
WALACOR_DISTILLATION_MIN_DIVERGENCES=500          # min student↔teacher divergences to trigger distillation
WALACOR_INTELLIGENCE_JUDGE_URL=http://localhost:8000/v1  # distillation judge endpoint; OpenAI-shape if URL ends /v1, else Ollama /api/chat
WALACOR_INTELLIGENCE_JUDGE_MODEL=claude-haiku-4-5 # model used as distillation judge (must be attested)
WALACOR_INTELLIGENCE_JUDGE_API_KEY=               # judge API key; empty = first WALACOR_GATEWAY_API_KEYS entry (self-loopback)
WALACOR_SHADOW_SAMPLE_TARGET=1000                 # target sample size for candidate shadow evaluation
WALACOR_SHADOW_MIN_ACCURACY_DELTA=0.02            # min accuracy improvement (vs production) to promote candidate
WALACOR_SHADOW_MAX_DISAGREEMENT=0.40              # max allowed candidate↔production disagreement rate
WALACOR_SHADOW_MAX_ERROR_RATE=0.05                # max allowed candidate inference error rate
WALACOR_AUTO_PROMOTE_MODELS=                      # comma-separated models eligible for auto-promotion (empty = human-in-loop)
WALACOR_TEACHER_LLM_URL=                          # teacher LLM URL for distillation labels (empty = disabled)
WALACOR_TEACHER_LLM_SAMPLE_RATE=0.01              # fraction of requests sampled for teacher labeling (0.0–1.0)

# ── Server ───────────────────────────────────────────────
WALACOR_GATEWAY_HOST=0.0.0.0
WALACOR_GATEWAY_PORT=8000
WALACOR_UVICORN_WORKERS=1              # >1 only with WALACOR_REDIS_URL set

# ── Observability ────────────────────────────────────────
WALACOR_METRICS_ENABLED=true
WALACOR_LOG_LEVEL=INFO

# ─────────────────────────────────────────────────────────────────────
# Additional Settings fields auto-listed for completeness.
# These fields have working code defaults; override only if needed.
# Kept in this file so the env-propagation lint test (
# tests/unit/test_env_propagation.py) stays green when new fields are
# added to src/gateway/config.py.
# ─────────────────────────────────────────────────────────────────────
# WALACOR_AB_TESTS_JSON=   # JSON array of A/B test configs. Example: [{"name":"size-test","model_pattern"...
