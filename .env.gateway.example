# WALACOR_ADAPTIVE_CONCURRENCY_MAX=100   # Max concurrency limit per provider
# WALACOR_ADAPTIVE_CONCURRENCY_MIN=5   # Min concurrency limit per provider
# WALACOR_ALERT_WEBHOOK_SECRET=   # Shared secret for HMAC-SHA256 signing of webhook alerts (X-Walacor-Signature)...
# WALACOR_ATTACHMENT_TRACKING_ENABLED=true   # Track file/image metadata in execution records
# WALACOR_CONTENT_ANALYSIS_PARALLEL=true   # Run input content analysis in parallel with LLM call (reduces latency for slo...
# WALACOR_CUSTOM_IDENTITY_VALIDATORS=   # Custom IdentityValidator classes
# WALACOR_CUSTOM_REQUEST_CLASSIFIERS=   # Custom RequestClassifier classes
# WALACOR_CUSTOM_RESOURCE_MONITORS=   # Custom ResourceMonitor classes
# WALACOR_CUSTOM_STARTUP_PROBES=   # Custom StartupProbe classes
# WALACOR_DISTILLATION_BUFFER_MAX=10000   # Maximum number of distillation samples retained in the IntelligenceWorker in-...
# WALACOR_DLP_ACTION_FINANCIAL=warn   # Action for financial data detection: warn or block
# WALACOR_DLP_ACTION_HEALTH=block   # Action for health/PHI data detection (HIPAA): warn or block
