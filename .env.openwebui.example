# ============================================================
# .env.openwebui — env for the gateway-openwebui container only.
#
# IMPORTANT: OPENAI_API_KEY here is the gateway's wgk-* admin key —
# OpenWebUI sends it as a *client* credential when calling the gateway.
# It is NOT an actual OpenAI account key (the real upstream OPENAI_API_KEY
# for the gateway's outbound calls lives in .env.gateway).
#
# Generate WEBUI_SECRET_KEY with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# Set it once and keep it unchanged across restarts — otherwise every
# restart invalidates all OpenWebUI session tokens and admins appear to
# "reset".
# ============================================================

# ── Gateway client credential ─────────────────────────────
# This must be ONE of the wgk-* values set in WALACOR_GATEWAY_API_KEYS in
# .env.gateway. OpenWebUI sends it as `Authorization: Bearer <value>` /
# `X-API-Key: <value>` when calling the gateway's /v1/chat/completions.
OPENAI_API_KEY=wgk-replace-with-your-gateway-api-key

# ── OpenWebUI display + behaviour ────────────────────────
WEBUI_NAME=Walacor Chat

# Stable session-signing key. Required for persistent logins across restarts.
# `python3 -c "import secrets; print(secrets.token_urlsafe(32))"`
WEBUI_SECRET_KEY=change-me-to-a-long-random-string

# Feature toggles — leave at these defaults unless you know why you're
# flipping one.
ENABLE_OLLAMA_API=false
ENABLE_FORWARD_USER_INFO_HEADERS=true
ENABLE_DIRECT_CONNECTIONS=false
ENABLE_SIGNUP=true
